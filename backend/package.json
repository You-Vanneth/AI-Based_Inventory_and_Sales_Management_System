{
  "name": "ai-inventory-sales-backend",
  "version": "1.0.0",
  "description": "Professional backend for AI-Based Inventory and Sales Management System",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "node src/server.js",
    "start": "node src/server.js",
    "db:bootstrap": "./scripts/bootstrap-db.sh",
    "test": "node --test $(rg --files tests -g '*.test.js' -g '!api-integration.test.js')",
    "test:api": "RUN_API_INTEGRATION=1 node --test tests/api-integration.test.js",
    "test:all": "npm test && npm run test:api",
    "check:syntax": "for f in $(rg --files src tests -g '*.js'); do node --check \"$f\" || exit 1; done",
    "school:qa": "npm run check:syntax && npm run test:all",
    "lint": "echo 'Lint setup pending'"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "mysql2": "^3.11.3",
    "nodemailer": "^6.9.15",
    "zod": "^3.23.8"
  }
}
